# Aleo Program ID
VITE_PROGRAM_ID=zkpowered_polls_app_mvp.aleo

# Aleo Network Configuration
PRIVATE_KEY=your_aleo_private_key_here
ENDPOINT=https://api.explorer.provable.com/v1

# Storacha (Web3.Storage) Configuration
# Required for IPFS-based poll storage
# All polls are stored on IPFS with CID committed on-chain
# Get credentials from: https://web3.storage/
VITE_STORACHA_KEY=your_storacha_key_here
VITE_STORACHA_PROOF=your_storacha_proof_here
VITE_STORACHA_SPACE_DID=your_space_did_here
